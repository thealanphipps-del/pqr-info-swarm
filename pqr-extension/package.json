{
  "name": "pqr-info-swarm",
  "displayName": "PQR Info Swarm",
  "description": "Forensic Ticketing Fabric and Agent Memory Interface for Antigravity",
  "version": "0.1.0",
  "publisher": "thealanphipps-del",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "pqr.openHUD",
        "title": "PQR: Open Heads-Up Display"
      },
      {
        "command": "pqr.initFabric",
        "title": "PQR: Initialize Ticketing Fabric"
      },
      {
        "command": "pqr.setupVault",
        "title": "PQR: Setup Vault (Sweep .env)"
      },
      {
        "command": "pqr.emergencyRepair",
        "title": "PQR: Emergency Sovereign Repair"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "pqr-swarm",
          "title": "PQR Swarm",
          "icon": "$(project)"
        }
      ]
    },
    "views": {
      "pqr-swarm": [
        {
          "id": "pqr.lineageView",
          "name": "Fabric Lineage"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/node": "16.x",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^5.59.8",
    "@typescript-eslint/parser": "^5.59.8",
    "eslint": "^8.41.0",
    "typescript": "^5.1.3"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.6.0",
    "@octokit/rest": "^22.0.1",
    "axios": "^1.4.0"
  }
}
